{
  "name": "Dev Container Example",
  "image": "jbayer/devcontainer-flox:1.12.1@sha256:972c46da0f5e2d80c17d2a8acab1591bf65f3476b0948410ee1db34299314a54",
  "features": {
      },
  "customizations": {
    "vscode": {
      "extensions": [
        "flox.flox",
        "ms-vscode-remote.remote-containers"
      ]
    }
  },
  "mounts": [
    "source=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/flox/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh/id_ed25519.pub,target=${localEnv:HOME}/.ssh/id_ed25519.pub,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh/allowed_signers,target=/home/flox/.ssh/allowed_signers,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh/known_hosts,target=/home/flox/.ssh/known_hosts,type=bind,readonly",
    "source=devcontainer-nix-store,target=/nix,type=volume",
    "source=${localWorkspaceFolderBasename}-flox-home,target=/home/flox,type=volume"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/run/host-services/ssh-auth.sock"
  },
  "runArgs": ["--group-add", "root"],
  "postStartCommand": "",
  "remoteUser": "flox"
}
